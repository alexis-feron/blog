# Generated by Ansible - do not edit manually
# {{ ansible_managed }}

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER={{ vault_postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB={{ vault_postgres_db }}

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD={{ vault_redis_password }}

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER={{ vault_minio_user }}
MINIO_ROOT_PASSWORD={{ vault_minio_password }}

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET={{ vault_jwt_secret }}
JWT_REFRESH_SECRET={{ vault_jwt_refresh_secret }}

# ── App / Reverse proxy ───────────────────────────────────────
NODE_ENV=production
# Public hostname served by the Traefik reverse proxy
DOMAIN={{ app_domain }}
# Site URL (CORS origin) and public API URL (browser → /api on the same host)
FRONTEND_URL={{ app_frontend_url | default('https://' ~ app_domain) }}
API_URL={{ app_api_url | default('https://' ~ app_domain ~ '/api') }}

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD={{ vault_grafana_password }}

# ── Alerting ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL={{ vault_discord_webhook_url }}
